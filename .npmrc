# pnpm configuration for GridGuard.
# The three.js / react-three ecosystem declares wide peer ranges; do not fail
# installs on non-fatal peer mismatches, but keep the lockfile strict.
auto-install-peers=true
strict-peer-dependencies=false
# Keep node_modules layout honest so import-boundary rules cannot be bypassed
# via phantom (hoisted) dependencies.
shamefully-hoist=false
save-exact=false
engine-strict=true
