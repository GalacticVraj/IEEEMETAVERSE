# Normalize line endings: LF in the repo, auto on checkout.
* text=auto eol=lf

# Enforce LF for source & config regardless of platform.
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary assets — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.mp3  binary
*.wav  binary
*.ogg  binary
*.glb  binary
*.gltf binary
*.hdr  binary
